# Copy to .env (gitignored) and fill in real values. Never commit .env.

VALUECLOUDS_EMAIL=
VALUECLOUDS_PASSWORD=

# PN / SN / devcode identify the specific inverter. No discovery endpoint
# is confirmed yet (see docs/api-reference.md) — capture these manually via
# your browser's DevTools Network tab while using the SmartValue/ValueClouds
# web app: look at the query string of a `deviceDats` request. Leave blank
# to run the harness in login-only mode.
VALUECLOUDS_PN=
VALUECLOUDS_SN=
VALUECLOUDS_DEVCODE=
